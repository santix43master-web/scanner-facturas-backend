{
  "expo": {
    "name": "Consulta Bienes",
    "slug": "consulta-bienes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1a73e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tu.consultabienes"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a73e8"
      },
      "package": "com.tu.consultabienes"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que $(PRODUCT_NAME) acceda a la cámara"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Permitir que $(PRODUCT_NAME) acceda a las fotos",
          "savePhotosPermission": "Permitir que $(PRODUCT_NAME) guarde fotos"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8da599fd-1383-467f-aa8b-f290a74d0dd8"
      }
    },
    "owner": "r21facturass"
  }
}
